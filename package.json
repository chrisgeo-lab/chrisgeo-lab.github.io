{
  "name": "routeflow",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Multi-stop route planner — static PWA, no build step.",
  "scripts": {
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint js/ tests/",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint --fix js/ tests/",
    "format": "prettier --write \"{js,tests,css}/**/*.{js,css}\" \"*.{html,md,json}\"",
    "format:check": "prettier --check \"{js,tests,css}/**/*.{js,css}\" \"*.{html,md,json}\"",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
